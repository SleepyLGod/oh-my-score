# Optional AI Sketch models. Copy to .env and fill only the model keys you use.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Preferred for mimo-v2.5-pro Token Plan keys. MIMO_API_KEY is also accepted as a compatibility alias.
XIAOMI_API_KEY=
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
